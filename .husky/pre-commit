echo "🔍 Pre-commit checks"

# Fast, reliable gate for every commit: the code must build and unit tests must pass.
# (Behavioral/E2E tests need real D1 content and run in the pre-push gate against the
# live site — a local dev server serves an empty local D1, so they can't run here.)

echo "📦 Building..."
if ! npm run build > /tmp/drbi-precommit-build.log 2>&1; then
  echo "❌ Build failed. Commit aborted."; tail -20 /tmp/drbi-precommit-build.log; exit 1
fi
echo "✅ Build OK"

echo "🧪 Unit tests..."
if ! npm run test:unit; then
  echo "❌ Unit tests failed. Commit aborted."; exit 1
fi

echo "✅ Pre-commit checks passed."
