echo "🚀 Pre-push gate"

# The behavioral tests need real D1 content, which a local dev server does NOT have
# (platformProxy uses an empty local D1). So we gate on: (1) the pushed code builds,
# (2) unit tests, (3) the behavioral suite against the LIVE deployed site (real content).
# Override the target with BASE_URL=... (e.g. the preview URL) if needed.

# 1) Build — catches compile/build breakage in the code being pushed
echo "📦 Building..."
if ! npm run build > /tmp/drbi-prepush-build.log 2>&1; then
  echo "❌ Build failed. Push aborted."; tail -20 /tmp/drbi-prepush-build.log; exit 1
fi
echo "✅ Build OK"

# 2) Unit tests — fast, reliable, no server needed
echo "🧪 Unit tests..."
if ! npm run test:unit; then
  echo "❌ Unit tests failed. Push aborted."; exit 1
fi

# 3) Behavioral gate against the live site (real content) — @smoke/@critical, excluding @known-bug
# --retry 2: only FAILED scenarios re-run, so genuine failures still block the push while
# transient network timeouts against the live site (Playwright full-page loads occasionally
# hang on external sub-resources) don't produce false negatives. Passing scenarios run once.
BASE_URL="${BASE_URL:-https://drbi.org}"
echo "🌐 Behavioral gate against $BASE_URL ..."
if ! BASE_URL="$BASE_URL" npx cucumber-js "tests/features/**/*.feature" \
     --import "tests/step-definitions/**/*.js" --import "tests/support/**/*.js" \
     --tags "(@smoke or @critical) and not @known-bug" --retry 2 --format progress-bar; then
  echo "❌ Behavioral tests failed against $BASE_URL. Push aborted."; exit 1
fi

echo "✅ Pre-push gate passed."
