---
export const prerender = false;

import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import PageHero from "@components/PageHero.astro";
import { getCollection } from 'astro:content';
import cemeteryImage from "./_memorial-garden-front.jpg";

let residents: any[] = [];
try {
  const allPosts = await getCollection('memorial');
  residents = allPosts
    .filter((p) => !p.data.draft && p.data.language === 'en')
    .sort((a, b) =>
      new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
    );
} catch (_e) {
  // renders empty state gracefully if collection unavailable
}
---

<Layout
  title="Desert Rose Memorial Cemetery"
  description="The Desert Rose Memorial Cemetery is a place of peace and tranquility in the Sonoran Desert, where loved ones rest and the living come to remember.">

  <PageHero
    label="Desert Rose Memorial Gardens"
    title="A Place of Peace & Rest"
    subtitle="An oasis of tranquility in the Sonoran Desert — where the lives of those who served are honored and remembered."
    image={cemeteryImage}
    imageAlt="Desert Rose Memorial Cemetery"
    imagePosition="object-center"
  />

  <section class="py-20 bg-white">
    <Container>
      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="text-slate-600 leading-relaxed text-lg italic">
          The Memorial Garden honors the dignity and celebrates the lives of dedicated service
          led by those who rest at Desert Rose. Founder Marguerite Sears and many past residents are interred here.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/the-bahai-faith"
             class="inline-block border border-amber-700 text-amber-800 px-8 py-3 rounded-full text-sm tracking-wide hover:bg-amber-50 transition duration-200">
            The Bahá'í Faith
          </a>
          <a href="/how-to-purchase-a-plot"
             class="inline-block bg-amber-700 text-white px-8 py-3 rounded-full text-sm tracking-wide hover:bg-amber-600 transition duration-200">
            Purchase a Plot
          </a>
        </div>
      </div>

      <div class="w-16 h-px bg-stone-200 mx-auto mb-16"></div>

      <h2 class="text-center text-3xl md:text-4xl font-serif font-light text-slate-800 mb-14">
        Permanent Residents
      </h2>

      {residents.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
          {residents.map((post) => (
            <a href={`/${post.data.url}`}
               class="group text-center hover:opacity-90 transition duration-200">
              {post.data.image?.src && (
                <div class="overflow-hidden rounded-lg aspect-square mb-3 bg-stone-100">
                  <img
                    src={post.data.image.src}
                    alt={post.data.image.alt || post.data.title}
                    class="w-full h-full object-cover object-top grayscale group-hover:grayscale-0 transition duration-500"
                    loading="lazy"
                  />
                </div>
              )}
              <p class="text-sm font-serif text-slate-700 leading-snug">{post.data.title}</p>
              {post.data.abstract && (
                <p class="text-xs text-slate-400 mt-1 leading-snug line-clamp-2">{post.data.abstract}</p>
              )}
            </a>
          ))}
        </div>
      ) : (
        <p class="text-center text-slate-400 text-sm">Memorial entries coming soon.</p>
      )}
    </Container>
  </section>

</Layout>
