---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import EventCalendar from "@components/EventCalendar.astro";
import SuperHero from "@components/superhero.astro";
import VideoPlayer from "@components/videoPlayer.astro";
import Testimonials from "@components/testimonials.astro";

import { Image } from "astro:assets";
import artsImg from "../assets/drbi/arts.webp";
import studyImg from "../assets/drbi/study.webp";
import soilImg from "../assets/drbi/soil.webp";
---

<Layout
  title="Desert Rose Bahá'í Institute"
  description="A school for the furtherance of arts, agriculture and Bahá'í education. Founded by Marguerite Sears."
  image="/drbi-landscape.webp"
>
  <div class="overflow-x-clip">

    <!-- 1. Hero -->
    <SuperHero />

    <!-- 2. What makes DRBI different -->
    <section class="py-16 md:py-28 bg-white">
      <Container>
        <div class="max-w-2xl mx-auto text-center mb-12 md:mb-20">
          <p class="text-xs uppercase tracking-[0.25em] text-amber-700 mb-8">What we offer</p>
          <p class="text-xl md:text-2xl font-serif font-light text-slate-700 leading-relaxed max-w-2xl mx-auto">
            A depth of Bahá'í education as envisioned by the Guardian — direct engagement with the writings of
            Bahá'u'lláh, 'Abdu'l-Bahá, and Shoghi Effendi himself, studied carefully and completely.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x divide-stone-200 max-w-5xl mx-auto">

          <!-- Scripture Study -->
          <div class="px-5 md:px-10 py-10 md:py-12 text-center">
            <div class="overflow-hidden rounded-xl aspect-video mb-8">
              <Image src={studyImg} alt="Deep study of scripture at DRBI" class="w-full h-full object-cover" />
            </div>
            <h3 class="text-xl font-serif text-slate-800 mb-4">Scripture Study</h3>
            <p class="text-slate-500 text-sm leading-relaxed">
              Not an introduction — a sustained, serious engagement with the primary writings
              of Bahá'u'lláh, 'Abdu'l-Bahá, and Shoghi Effendi that can reorient how you
              understand yourself and the world.
            </p>
            <p class="mt-5 text-xs text-amber-700 italic leading-relaxed">
              "By faith is meant, first, conscious knowledge."
            </p>
            <p class="text-xs text-slate-400 mt-1">— 'Abdu'l-Bahá, <em>Tablets of 'Abdu'l-Bahá, Vol. 3</em></p>
          </div>

          <!-- Arts -->
          <div class="px-5 md:px-10 py-10 md:py-12 text-center">
            <div class="overflow-hidden rounded-xl aspect-video mb-8">
              <Image src={artsImg} alt="The Fine Arts at DRBI" class="w-full h-full object-cover" />
            </div>
            <h3 class="text-xl font-serif text-slate-800 mb-4">The Arts</h3>
            <p class="text-slate-500 text-sm leading-relaxed">
              Music, visual art, performance — not as decoration but as a form of service.
              The Bahá'í writings speak of art as one of the most powerful forces for
              transforming hearts and spreading a vision of unity.
            </p>
            <p class="mt-5 text-xs text-amber-700 italic leading-relaxed">
              "Music is one of the arts that is of benefit — a cause of the exaltation of the human spirit."
            </p>
            <p class="text-xs text-slate-400 mt-1">— 'Abdu'l-Bahá, <em>The Promulgation of Universal Peace</em></p>
          </div>

          <!-- Agriculture -->
          <div class="px-5 md:px-10 py-10 md:py-12 text-center">
            <div class="overflow-hidden rounded-xl aspect-video mb-8">
              <Image src={soilImg} alt="Agriculture and the soil at DRBI" class="w-full h-full object-cover" />
            </div>
            <h3 class="text-xl font-serif text-slate-800 mb-4">Agriculture</h3>
            <p class="text-slate-500 text-sm leading-relaxed">
              The soil is not background. It is curriculum. Working the land is both
              practical and spiritual — a way of understanding what it means to be
              a steward of the earth and a producer, not just a consumer.
            </p>
            <p class="mt-5 text-xs text-amber-700 italic leading-relaxed">
              "The fundamental basis of the community is agriculture, tillage of the soil."
            </p>
            <p class="text-xs text-slate-400 mt-1">— 'Abdu'l-Bahá, <em>The Promulgation of Universal Peace</em></p>
          </div>

        </div>
      </Container>
    </section>

    <!-- 3. Upcoming Programs -->
    <section id="programs" class="py-24 bg-stone-50">
      <Container>
        <div class="text-center mb-14">
          <p class="text-xs uppercase tracking-[0.25em] text-amber-700 mb-4">What's happening</p>
          <h2 class="text-3xl md:text-4xl font-serif font-light text-slate-800">Upcoming Programs & Classes</h2>
          <p class="mt-4 text-slate-400 max-w-lg mx-auto">
            Classes, workshops, retreats, and intensives. Open to everyone — Bahá'í and non-Bahá'í alike.
          </p>
        </div>
        <EventCalendar view="timeline" />
        <div class="text-center mt-12">
          <a href="/events"
            class="inline-block border border-slate-300 text-slate-600 px-10 py-3.5 rounded-full text-sm tracking-wide hover:bg-white hover:shadow-sm transition duration-200">
            View All Programs
          </a>
        </div>
      </Container>
    </section>

    <!-- 5. Agriculture — its own moment -->
    <section class="py-0 bg-white">
      <div class="grid grid-cols-1 md:grid-cols-2 min-h-[500px]">
        <div class="overflow-hidden">
          <Image src={soilImg} alt="Working the soil at DRBI" class="w-full h-full object-cover min-h-[400px]" />
        </div>
        <div class="flex flex-col justify-center px-6 md:px-12 py-12 md:py-20 bg-amber-50">
          <p class="text-xs uppercase tracking-[0.25em] text-amber-700 mb-5">Working the Land</p>
          <h2 class="text-3xl md:text-4xl font-serif font-light text-slate-800 leading-snug">
            Grow food.<br>Understand the earth.<br>Become a producer.
          </h2>
          <p class="mt-7 text-slate-600 leading-relaxed">
            At DRBI, agriculture is not a hobby. It is one of the central expressions of our mission.
            The Bahá'í writings make clear that every person should be a producer — someone who
            gives back to the world, not only takes from it.
          </p>
          <p class="mt-5 text-slate-600 leading-relaxed">
            Working the land here means learning to grow food in a desert climate,
            understanding permaculture and sustainable farming, and participating in
            something that feeds both the body and the soul.
          </p>
          <a href="/agriculture"
            class="mt-10 self-start text-sm text-amber-800 border-b border-amber-700/30 hover:border-amber-700 pb-0.5 tracking-wide transition duration-200">
            Learn about our agricultural vision &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- 6. Founder's voice -->
    <section class="py-24 bg-white">
      <Container>
        <div class="text-center mb-12">
          <p class="text-xs uppercase tracking-[0.25em] text-amber-700 mb-4">Our Founder</p>
          <h2 class="text-3xl md:text-4xl font-serif font-light text-slate-800">
            Hear Marguerite Sears speak<br>about why Desert Rose exists
          </h2>
        </div>
        <VideoPlayer
          video="https://www.youtube.com/embed/HbHLSZoy7bw?si=ElAKh9mwXq03oGhd"
          thumbnail={true}
          title="Marguerite Sears speaks about Desert Rose"
        />
      </Container>
    </section>

    <!-- 7. Planning to visit -->
    <section class="py-24 bg-stone-50">
      <Container>
        <div class="max-w-2xl mx-auto text-center">
          <p class="text-xs uppercase tracking-[0.25em] text-amber-700 mb-5">Planning to Come</p>
          <h2 class="text-3xl md:text-4xl font-serif font-light text-slate-800 mb-7">
            Stay on the grounds
          </h2>
          <p class="text-slate-500 text-lg leading-relaxed">
            DRBI offers accommodation on our property in Eloy, Arizona — whether you're
            coming for a program, a personal retreat, or to gather with family and friends
            for a special occasion. Our listings with full details, photos, and availability
            are on Airbnb and Evolve.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <!-- Replace # below with actual Airbnb listing URL -->
            <span role="link" aria-disabled="true"
              class="inline-block bg-[#FF5A5F] text-white px-8 py-4 rounded-full text-sm tracking-wide opacity-90 cursor-not-allowed">
              Find us on Airbnb
            </span>
            <!-- Replace # below with actual Evolve listing URL -->
            <span role="link" aria-disabled="true"
              class="inline-block bg-slate-800 text-white px-8 py-4 rounded-full text-sm tracking-wide opacity-90 cursor-not-allowed">
              Find us on Evolve
            </span>
          </div>
          <p class="mt-8 text-slate-400 text-sm">
            Questions about facilities or rentals?
            <a href="/facilities-and-rentals" class="text-amber-700 hover:underline">See our facilities page</a>
            or <a href="/contact-us" class="text-amber-700 hover:underline">contact us directly</a>.
          </p>
        </div>
      </Container>
    </section>

    <!-- 8. Testimonials -->
    <Testimonials />

    <!-- 9. Stay connected -->
    <section class="py-16 md:py-28 bg-slate-800 text-white text-center">
      <Container>
        <p class="text-xs uppercase tracking-[0.25em] text-amber-400 mb-5">Stay Connected</p>
        <h2 class="text-3xl md:text-5xl font-serif font-light leading-snug max-w-xl mx-auto">
          Keep Desert Rose<br>in your life
        </h2>
        <p class="mt-7 text-slate-300 max-w-md mx-auto text-base leading-relaxed">
          News about upcoming programs, classes, and the life of the community.
          No clutter — just what matters.
        </p>
        <a href="http://eepurl.com/gTGwNH" target="_blank" rel="noopener noreferrer"
          class="mt-10 inline-block bg-amber-600 hover:bg-amber-500 text-white px-10 py-4 rounded-full text-sm tracking-[0.15em] uppercase transition duration-200">
          Join Our Newsletter
        </a>
        <div class="mt-6">
          <a href="/contribute"
            class="text-slate-400 hover:text-amber-400 text-sm tracking-wide transition duration-200">
            Or make a gift to support our work &rarr;
          </a>
        </div>
      </Container>
    </section>

  </div>
</Layout>
