---
export const prerender = false;

import Layout from '@layouts/AdminLayout.astro';
import { getUserById, createUser, updateUser } from '@lib/queries';
import { Argon2id } from 'oslo/password';

const currentUser = Astro.locals?.user;
if (!currentUser || !['superadmin', 'admin'].includes(currentUser.role)) return Astro.redirect('/admin');

const { id } = Astro.params;
const isNew = id === 'add';

let userData = isNew ? null : await getUserById(id!);
if (!isNew && !userData) return Astro.redirect('/admin/users');

let errorMsg = '';
let successMsg = '';

const ROLES = ['author', 'editor', 'admin', 'superadmin'];
const availableRoles = currentUser.role === 'superadmin' ? ROLES : ROLES.filter(r => r !== 'superadmin');

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const name = (fd.get('name') as string)?.trim();
  const email = (fd.get('email') as string)?.trim().toLowerCase();
  const role = fd.get('role') as string;
  const password = (fd.get('password') as string)?.trim();
  const active = fd.get('active') !== 'false';

  if (!name || !email) { errorMsg = 'Name and email are required.'; }
  else if (!ROLES.includes(role)) { errorMsg = 'Invalid role.'; }
  else if (role === 'superadmin' && currentUser.role !== 'superadmin') { errorMsg = 'Only superadmin can grant superadmin.'; }
  else {
    try {
      if (isNew) {
        if (!password) { errorMsg = 'Password is required for new users.'; }
        else {
          const argon = new Argon2id();
          const hashed_password = await argon.hash(password);
          const newId = email.replace(/[^a-z0-9]/g, '-');
          await createUser({ id: newId, email, hashed_password, name, role });
          return Astro.redirect('/admin/users');
        }
      } else {
        const updates: Record<string, any> = { name, email, role, active };
        if (password) {
          const argon = new Argon2id();
          updates.hashed_password = await argon.hash(password);
        }
        await updateUser(id!, updates);
        successMsg = 'User updated successfully.';
        userData = await getUserById(id!);
      }
    } catch (e: any) {
      errorMsg = e.message?.includes('UNIQUE') ? 'Email already in use.' : 'Error saving user.';
    }
  }
}

const form = userData ?? { name: '', email: '', role: 'author', active: 1 };
---

<Layout title={isNew ? 'Add User' : `Edit: ${form.name}`} user={currentUser}>
  <div class="max-w-2xl mx-auto px-6 py-6">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900 mb-1">{isNew ? 'Add User' : `Edit: ${form.name}`}</h1>
      <nav class="text-sm text-gray-500">
        <a href="/" class="hover:text-blue-600">home</a> /
        <a href="/admin" class="hover:text-blue-600">admin</a> /
        <a href="/admin/users" class="hover:text-blue-600">users</a> /
        {isNew ? 'add' : form.name}
      </nav>
    </div>

    {errorMsg && <div class="bg-red-50 border border-red-300 text-red-700 px-4 py-3 rounded mb-4">{errorMsg}</div>}
    {successMsg && <div class="bg-green-50 border border-green-300 text-green-700 px-4 py-3 rounded mb-4">{successMsg}</div>}

    <form method="POST" class="bg-white shadow-sm rounded-lg p-6 space-y-5">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
          <input type="text" name="name" required value={form.name}
                 class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
          <input type="email" name="email" required value={form.email}
                 class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Role *</label>
          <select name="role" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500">
            {availableRoles.map(r => (
              <option value={r} selected={r === form.role}>{r}</option>
            ))}
          </select>
        </div>
        {!isNew && (
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select name="active" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500">
              <option value="true" selected={form.active !== 0}>Active</option>
              <option value="false" selected={form.active === 0}>Disabled</option>
            </select>
          </div>
        )}
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          {isNew ? 'Password *' : 'New Password'} {!isNew && <span class="text-gray-400 font-normal">(leave blank to keep current)</span>}
        </label>
        <input type="password" name="password" required={isNew} minlength="8"
               placeholder={isNew ? 'Min 8 characters' : 'Leave blank to keep current'}
               class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" />
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700">
          {isNew ? 'Create User' : 'Save Changes'}
        </button>
        <a href="/admin/users" class="px-5 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200">
          Cancel
        </a>
      </div>
    </form>
  </div>
</Layout>
