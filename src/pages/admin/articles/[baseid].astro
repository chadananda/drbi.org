---
// src/pages/admin/articles/[baseid].astro — SSR article editor; uses D1 via queries (no cms-utils)
export const prerender = false;

import Layout from '@layouts/AdminLayout.astro';
import site from '@data/site.json';
import { getContentBySlug, getContentByCollection } from '@lib/queries';
import { getTeam, getTopics, getCategories, mainLanguages } from '@utils/utils';
const langs = mainLanguages;
import PostEditor from '@components/admin/PostEditor.svelte';

const user = Astro.locals.user;
const baseid = Astro.params.baseid;

const row = await getContentBySlug(baseid);
if (!row) return Astro.redirect('/admin/articles');

// Build post shape: Editor needs post.content; MetaEditor needs post.frontmatter + flat fields
const d = row.data;
const toDateStr = (v) => v instanceof Date ? v.toISOString().split('T')[0] : (v || '');
const post = {
  id: row.id, baseid: row.baseid, collection: row.collection,
  body: row.body, content: row.body,
  frontmatter: d,
  language: d.language, title: d.title, description: d.description,
  desc_125: d.desc_125, abstract: d.abstract, url: d.url,
  post_type: d.post_type, draft: d.draft, author: d.author, editor: d.editor,
  category: d.category, topics: d.topics, keywords: d.keywords,
  datePublished: toDateStr(d.datePublished), image: d.image?.src || '',
  audio: d.audio, audio_image: d.audio_image, narrator: d.narrator,
};

// Translations: remap D1 ids ("articles/slug/en") to old format ("articles/en/slug.md")
// so PostEditor's idLang() fn (splits on '/' at [1]) correctly extracts the language code
const allArticles = await getContentByCollection('articles');
const translations = allArticles
  .filter(p => p.baseid === baseid)
  .map(p => `${p.collection}/${p.data.language}/${p.baseid}.md`);

const authorList = (await getTeam()).map(({id}) => id);
const topicList = (await getTopics()).map(({id}) => id);
const categoryList = (await getCategories()).map(({id}) => id);

const languages = site.languages.map(ln => ({ ...langs[ln], id: ln }))
  .sort((a, b) => a.id === 'en' ? -1 : b.id === 'en' ? 1 : a.id.localeCompare(b.id));
const sessionid = Astro.locals.session.id;
const language = post.frontmatter?.language || 'en';

const editorObjects = { baseid, language, site, translations, authorList, topicList, categoryList, languages, sessionid, post };
---

<Layout menu="compact">
<div class="w-full mx-5 -ml-2 mr-10 no-prose">
    <PostEditor {...editorObjects} client:only />
</div>
</Layout>
