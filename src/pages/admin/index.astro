---
// Admin dashboard — a summary of everything (content, events, team, users) plus a compact
// analytics glance that links to the full Analytics page.
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { getContentByCollection, getUpcomingEvents, getTeam, getUsers } from '@lib/queries';
import { getAnalytics } from '@lib/analytics';
import { roleLevel } from '@lib/admin-nav';

const user = Astro.locals?.user;
const level = roleLevel(user?.role);

let articles = [], news = [], memorial = [], events = [], team = [], users = [];
try {
  [articles, news, memorial, events, team, users] = await Promise.all([
    getContentByCollection('articles').catch(() => []),
    getContentByCollection('news').catch(() => []),
    getContentByCollection('memorial').catch(() => []),
    getUpcomingEvents().catch(() => []),
    getTeam().catch(() => []),
    level >= 40 ? getUsers().catch(() => []) : Promise.resolve([]),
  ]);
} catch (e) { console.error('dashboard load error', e); }

const analytics = await getAnalytics(30);
const fmt = (n) => Math.round(n).toLocaleString('en-US');

const draftCount = [...articles, ...news, ...memorial].filter((p) => p.data?.draft).length;
const recent = [...articles.map((p) => ({ ...p, _c: 'articles' })), ...news.map((p) => ({ ...p, _c: 'news' }))]
  .filter((p) => p.data?.datePublished)
  .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime())
  .slice(0, 6);
const fmtDate = (s) => { try { return new Date(s).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); } catch { return ''; } };

// Stat cards, gated by role where relevant.
const stats = [
  { label: 'Articles', value: articles.length, href: '/admin/articles', icon: '📝', show: true },
  { label: 'News', value: news.length, href: '/admin/news', icon: '📰', show: true },
  { label: 'Memorial', value: memorial.length, href: '/admin/memorial', icon: '🕊️', show: true },
  { label: 'Upcoming events', value: events.length, href: '/admin/events', icon: '📅', show: level >= 30 },
  { label: 'Team', value: team.length, href: '/admin/team', icon: '👥', show: level >= 40 },
  { label: 'Users', value: users.length, href: '/admin/users', icon: '🔑', show: level >= 100 },
].filter((s) => s.show);

const quickActions = [
  { label: 'New article', href: '/admin/articles/new', icon: '✍️', show: true },
  { label: 'New event', href: '/admin/events', icon: '📅', show: level >= 30 },
  { label: 'Media library', href: '/admin/media', icon: '🖼️', show: true },
  { label: 'Full analytics', href: '/admin/analytics', icon: '📊', show: level >= 40 },
].filter((a) => a.show);
---

<AdminLayout title="Dashboard" user={user}>
  <div class="w-full">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
      <p class="text-sm text-gray-500 mt-1">Welcome back{user?.name ? `, ${user.name}` : ''} — here's an overview of the site.</p>
    </div>

    <!-- Stat cards -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
      {stats.map((s) => (
        <a href={s.href} class="bg-white border border-gray-200 rounded-2xl p-4 shadow-sm hover:shadow-md hover:border-amber-300 transition group">
          <div class="text-2xl mb-1" aria-hidden="true">{s.icon}</div>
          <div class="text-2xl font-bold text-gray-900 tabular-nums">{fmt(s.value)}</div>
          <div class="text-xs text-gray-500 group-hover:text-amber-700">{s.label}</div>
        </a>
      ))}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Recent content -->
      <div class="lg:col-span-2 bg-white border border-gray-200 rounded-2xl p-5 sm:p-6 shadow-sm">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">Recent content</h2>
          {draftCount > 0 && <span class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-full px-2.5 py-1">{draftCount} draft{draftCount === 1 ? '' : 's'}</span>}
        </div>
        <div class="divide-y divide-gray-100">
          {recent.length === 0 && <p class="text-sm text-gray-400">No content yet.</p>}
          {recent.map((p) => (
            <a href={`/admin/${p._c}/${p.baseid}`} class="flex items-center justify-between py-2.5 group">
              <span class="min-w-0 pr-3">
                <span class="block text-sm font-medium text-gray-800 truncate group-hover:text-amber-700">{p.data?.title || '(untitled)'}</span>
                <span class="block text-xs text-gray-400 capitalize">{p._c}{p.data?.draft ? ' · draft' : ''}</span>
              </span>
              <span class="text-xs text-gray-400 shrink-0">{fmtDate(p.data?.datePublished)}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Sidebar column: analytics glance + quick actions -->
      <div class="space-y-6">
        <div class="bg-white border border-gray-200 rounded-2xl p-5 sm:p-6 shadow-sm">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-lg font-semibold text-gray-900">Traffic</h2>
            <span class="text-xs text-gray-400">30 days</span>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <div class="text-2xl font-bold text-gray-900 tabular-nums">{fmt(analytics.totals.pageviews)}</div>
              <div class="text-xs text-gray-500">Page views</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-gray-900 tabular-nums">{fmt(analytics.totals.visits)}</div>
              <div class="text-xs text-gray-500">Visits</div>
            </div>
          </div>
          {level >= 40 && <a href="/admin/analytics" class="inline-block mt-4 text-sm font-medium text-amber-700 hover:text-amber-800">View full analytics →</a>}
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-5 sm:p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-gray-900 mb-3">Quick actions</h2>
          <div class="space-y-1.5">
            {quickActions.map((a) => (
              <a href={a.href} class="flex items-center gap-2.5 px-3 py-2 text-sm text-gray-700 rounded-lg hover:bg-amber-50 hover:text-amber-800 transition">
                <span aria-hidden="true">{a.icon}</span>{a.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
