---
export const prerender = false;
export const ssr = true;

import { lucia, adminUser } from '@lib/auth';
import Layout from "@layouts/Layout.astro";
import { logoutUser } from '@utils/utils';
import { resolveUserByEmail } from '@lib/whitelist';
import { startSession } from '@lib/session';

// If already signed in, log out and land back on a clean login.
if (Astro.locals?.user) {
  await logoutUser(Astro);
  return Astro.redirect('/login', 303);
}

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
let errorMsg = '';
const qError = new URL(Astro.request.url).searchParams.get('error');
if (qError === 'not-authorized') errorMsg = 'That email is not authorized for admin access.';
else if (qError === 'invalid-or-expired') errorMsg = 'That sign-in link was invalid or expired. Request a new one.';

// Break-glass: env superadmin password login (POST from the password form).
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = (formData.get('email') as string || '').trim().toLowerCase();
  const password = (formData.get('password') as string || '').trim();
  const envEmail = import.meta.env.SITE_ADMIN_EMAIL?.trim().toLowerCase();
  const envPassword = import.meta.env.SITE_ADMIN_PASS?.trim();
  if (envEmail && envPassword && email === envEmail && password === envPassword) {
    const user = await resolveUserByEmail(email);
    if (user) {
      await startSession(Astro, user.id, user.role);
      return Astro.redirect('/admin', 303);
    }
  }
  errorMsg = 'Invalid email or password.';
}
---

<Layout title="Administration Login">
  <div class="flex justify-center items-center bg-gray-100 py-10 min-h-[80vh]">
    <div class="w-full max-w-sm">
      <div class="bg-white shadow-md rounded px-8 pt-6 pb-6 mb-4">
        <h1 class="text-lg font-semibold text-gray-800 mb-1">Admin sign-in</h1>
        <p class="text-sm text-gray-500 mb-5">Use your authorized email.</p>

        <div id="error-message" role="alert">
          {errorMsg && <p class="text-red-500 text-sm mb-3">{errorMsg}</p>}
        </div>
        <div id="js-message" class="text-sm mb-3"></div>

        {googleClientId && (
          <div class="mb-5">
            <div id="g_id_onload"
                 data-client_id={googleClientId}
                 data-callback="handleGoogle"
                 data-auto_prompt="true"></div>
            <div class="g_id_signin" data-type="standard" data-width="304"></div>
          </div>
        )}

        <form id="magic-form" class="mb-2">
          <label class="block text-gray-700 text-sm font-bold mb-2" for="magic-email">Email</label>
          <input type="email" id="magic-email" name="email" required
                 class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline mb-3" />
          <button type="submit"
                  class="w-full bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline">
            Email me a sign-in link
          </button>
        </form>

        <details class="mt-4">
          <summary class="text-xs text-gray-400 cursor-pointer">Superadmin password (break-glass)</summary>
          <form id="login-form" method="POST" class="mt-3">
            <input type="email" name="email" placeholder="Email" required
                   class="shadow border rounded w-full py-2 px-3 text-gray-700 mb-2 text-sm" />
            <input type="password" name="password" placeholder="Password" required
                   class="shadow border rounded w-full py-2 px-3 text-gray-700 mb-2 text-sm" />
            <button type="submit" class="text-sm bg-gray-700 hover:bg-gray-900 text-white py-2 px-4 rounded">Sign In</button>
          </form>
        </details>
      </div>
    </div>
  </div>

  {googleClientId && <script is:inline src="https://accounts.google.com/gsi/client" async></script>}

  <script is:inline>
    // Google One Tap callback (global, referenced by data-callback)
    window.handleGoogle = async (response) => {
      const msg = document.getElementById('js-message');
      try {
        const r = await fetch('/api/auth/google', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ credential: response.credential }),
        });
        const data = await r.json();
        if (data.ok) { window.location.href = data.redirect || '/admin'; }
        else { msg.textContent = data.error === 'not-authorized' ? 'That Google account is not authorized.' : 'Google sign-in failed.'; msg.className = 'text-red-500 text-sm mb-3'; }
      } catch { msg.textContent = 'Google sign-in failed.'; msg.className = 'text-red-500 text-sm mb-3'; }
    };

    // Email magic-link request
    document.getElementById('magic-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('magic-email')).value.trim();
      const msg = document.getElementById('js-message');
      await fetch('/api/auth/request-link', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      }).catch(() => {});
      msg.textContent = 'If that email is authorized, a sign-in link is on its way. Check your inbox.';
      msg.className = 'text-green-600 text-sm mb-3';
    });
  </script>
</Layout>
