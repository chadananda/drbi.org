---
export const prerender = false;
import Layout from "@layouts/Layout.astro";
import Container from "src/components/container.astro";
import PageHero from "@components/PageHero.astro";
import site from "@data/site.json";
import aboutusimg from "./_about_us.webp";
---

<Layout title="About Desert Rose" description="Learn about the mission, board, team, and community of Desert Rose Bahá'í Institute.">

  <PageHero
    label="Who we are"
    title="About Desert Rose"
    subtitle="A community of learners, servants, and builders — guided by the Bahá'í Faith, open to the world."
    image={aboutusimg}
    imageAlt="Desert Rose Bahá'í Institute"
  />

  <!-- Vision & Mission -->
  <section class="py-24 bg-white">
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-xs uppercase tracking-[0.25em] text-amber-700 mb-4">Our Purpose</p>
          <h2 class="text-3xl md:text-4xl font-serif font-light text-slate-800">Vision & Mission</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 text-slate-600 leading-relaxed text-base">
          <div>
            <h3 class="font-serif text-xl text-slate-800 mb-4">Our Vision</h3>
            <p>Desert Rose is a community-based center of learning, guided by Bahá'í principles, that creates an atmosphere of spirituality which inspires positive human development.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl text-slate-800 mb-4">Our Mission</h3>
            <p>To serve the community at large through phased development of activities and institutions that promote spiritual, artistic, intellectual, agricultural, and other practical education for people of all ages and backgrounds.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Board of Directors -->
  <section class="py-24 bg-stone-50">
    <Container>
      <div class="text-center mb-14">
        <p class="text-xs uppercase tracking-[0.25em] text-amber-700 mb-4">Leadership</p>
        <h2 class="text-3xl md:text-4xl font-serif font-light text-slate-800">Board of Directors</h2>
        <p class="mt-4 text-slate-400 max-w-md mx-auto">Appointed by the Local Spiritual Assembly of the Bahá'ís of Scottsdale, Arizona.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">

        <div class="bg-white rounded-2xl p-8 flex gap-6 shadow-sm">
          <img src="https://drbi.s3.amazonaws.com/uploads/2024-05-31-default-slug-taj_profile.webp"
            alt="Taj Sabet"
            class="w-20 h-20 rounded-full object-cover shrink-0 border-2 border-stone-100" />
          <div>
            <h3 class="font-serif text-lg text-slate-800">Taj Sabet</h3>
            <p class="text-xs text-amber-700 uppercase tracking-widest mb-2">Chairman</p>
            <p class="text-slate-500 text-sm leading-relaxed">Trilingual businessman and entrepreneur, serving as Chairman for six years. Great-grandson of Shu'a'u'lláh 'A'lá'í, one of the two Hands of the Cause to whom the institute is dedicated.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 flex gap-6 shadow-sm">
          <img src="https://drbi.s3.amazonaws.com/uploads/2024-05-31-default-slug-marguerite_profile.webp"
            alt="Marguerite Sears"
            class="w-20 h-20 rounded-full object-cover shrink-0 border-2 border-stone-100" />
          <div>
            <h3 class="font-serif text-lg text-slate-800">Marguerite Sears</h3>
            <p class="text-xs text-amber-700 uppercase tracking-widest mb-2">Board Member</p>
            <p class="text-slate-500 text-sm leading-relaxed">Namesake and granddaughter of the founder of DRBI. Specializes in envisioning events and activities that share Desert Rose with the world.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 flex gap-6 shadow-sm">
          <img src="https://drbi.s3.amazonaws.com/uploads/2024-05-31-default-slug-dwight_profile.webp"
            alt="Dwight Cox"
            class="w-20 h-20 rounded-full object-cover shrink-0 border-2 border-stone-100" />
          <div>
            <h3 class="font-serif text-lg text-slate-800">Dwight Cox</h3>
            <p class="text-xs text-amber-700 uppercase tracking-widest mb-2">Vice-Chair & Interim Treasurer</p>
            <p class="text-slate-500 text-sm leading-relaxed">Joined the board in 2015. Now retired from his Aviation business and devoting his time to DRBI's Agriculture program, reclaiming the desert as viable land.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 flex gap-6 shadow-sm">
          <img src="https://drbi.s3.amazonaws.com/uploads/2024-06-02-default-slug-IMG_4876.JPG"
            alt="Chad Jones"
            class="w-20 h-20 rounded-full object-cover shrink-0 border-2 border-stone-100" />
          <div>
            <h3 class="font-serif text-lg text-slate-800">Chad Jones</h3>
            <p class="text-xs text-amber-700 uppercase tracking-widest mb-2">Executive Director</p>
            <p class="text-slate-500 text-sm leading-relaxed">Alaskan fisherman and software developer with a deep interest in Bahá'í education. Believes the guidance of the Guardian speaks not only to the past, but to our future.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 flex gap-6 shadow-sm">
          <img src="https://drbi.s3.amazonaws.com/uploads/2024-05-31-default-slug-pete_smith.webp"
            alt="Pete Smith"
            class="w-20 h-20 rounded-full object-cover shrink-0 border-2 border-stone-100" />
          <div>
            <h3 class="font-serif text-lg text-slate-800">Pete Smith</h3>
            <p class="text-xs text-amber-700 uppercase tracking-widest mb-2">Board Member</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 flex gap-6 shadow-sm">
          <div class="w-20 h-20 rounded-full bg-stone-100 shrink-0 flex items-center justify-center text-stone-400 text-2xl font-serif">VA</div>
          <div>
            <h3 class="font-serif text-lg text-slate-800">Vafa Aflatooni</h3>
            <p class="text-xs text-amber-700 uppercase tracking-widest mb-2">Board Member</p>
          </div>
        </div>

      </div>
    </Container>
  </section>

  <!-- Core Team -->
  <section class="py-24 bg-white">
    <Container>
      <div class="text-center mb-14">
        <p class="text-xs uppercase tracking-[0.25em] text-amber-700 mb-4">Day to Day</p>
        <h2 class="text-3xl md:text-4xl font-serif font-light text-slate-800">Our Core Team</h2>
        <p class="mt-4 text-slate-400 max-w-md mx-auto">As a 501(c)(3) nonprofit, DRBI relies on skilled, dedicated individuals to keep the Institute running.</p>
      </div>

      <div class="max-w-3xl mx-auto space-y-5">
        {[
          { name: "Tim McKenna", role: "Facilities Manager" },
          { name: "Robin Springfield", role: "Facilities Assistant" },
          { name: "Telahoun Molla", role: "Operations Manager" },
          { name: "Brooke Molla", role: "Landscape Redesign" },
          { name: "Chris Ruhe", role: "Radio Station Manager" },
        ].map(person => (
          <div class="flex items-center gap-6 py-4 border-b border-stone-100 last:border-0">
            <div class="w-10 h-10 rounded-full bg-amber-50 border border-amber-100 shrink-0 flex items-center justify-center text-amber-700 text-xs font-serif font-medium">
              {person.name.split(' ').map(n => n[0]).join('').slice(0,2)}
            </div>
            <div>
              <p class="font-serif text-slate-800">{person.name}</p>
              <p class="text-sm text-amber-700 tracking-wide">{person.role}</p>
            </div>
          </div>
        ))}

        <!-- Janet Ruhe-Schoen gets special treatment -->
        <div class="flex items-start gap-6 py-6 border-b border-stone-100">
          <img src="/documents/Janet-Ruhe-Schoen.jpg"
            alt="Janet Ruhe-Schoen"
            class="w-16 h-16 rounded-full object-cover shrink-0 border-2 border-stone-100" />
          <div>
            <p class="font-serif text-slate-800">Janet Ruhe-Schoen</p>
            <p class="text-sm text-amber-700 tracking-wide mb-3">In-Residence Scholar and Author</p>
            <p class="text-slate-500 text-sm leading-relaxed">
              Author of <em>A Love Which Does Not Wait</em>, <em>Rejoice in My Gladness: The Life of Táhirih</em>,
              <em>Champions of Oneness: Louis Gregory and His Shining Circle</em>, and more.
              Bahá'í pioneer, journalist, vocalist, visual artist, poet, and editor of DRBI's quarterly newsletter.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Volunteer Community -->
  <section class="py-24 bg-amber-50">
    <Container>
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs uppercase tracking-[0.25em] text-amber-700 mb-4">The Heart of DRBI</p>
        <h2 class="text-3xl md:text-4xl font-serif font-light text-slate-800 mb-7">
          Our Community of Volunteers
        </h2>
        <p class="text-slate-600 leading-relaxed text-base">
          You may call them Volunteers. We call them extraordinary.
          Bonnie Tozer, Nancy Sloman, Doris and Roger Rasmussen, Sandra Parm, Deepali Jones,
          Marylou Strawway, Jean and Duffy Sheridan, Ladjamaya Gren, Glenn and Nancy Darling,
          Chris and Janet Ruhe-Schoen, Kitty and Mark Lutness, Mooi Yong Ng Khosraviani,
          Kelly Hadden — and many more who have given their time and love to this place.
        </p>
        <a href="/working-with-us"
          class="mt-10 inline-block bg-slate-800 hover:bg-slate-700 text-white px-10 py-4 rounded-full text-sm tracking-[0.15em] uppercase transition duration-200">
          Become a Volunteer
        </a>
      </div>
    </Container>
  </section>

  <!-- Contact CTA -->
  <section class="py-20 bg-slate-800 text-white text-center">
    <Container>
      <h2 class="text-2xl md:text-4xl font-serif font-light mb-5">Have questions about DRBI?</h2>
      <a href="/contact-us" class="inline-block border border-white/40 text-white/85 px-8 py-3 rounded-full text-sm tracking-wide hover:bg-white/10 transition duration-200">
        Get in Touch
      </a>
    </Container>
  </section>

</Layout>
