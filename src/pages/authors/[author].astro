---
export const prerender = false;

import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import PostThumb from "@components/article/postThumb.astro";
import AuthorCard from "@components/article/authorCard.astro";
import { getCategories, getPublishedArticles, getTeam } from "@utils/utils.js";

// this author param
const author_slug = Astro.params.author;
const allAuthors = await getTeam();
const author = allAuthors.find((a) => a.id === author_slug);
if (!author) return Astro.rewrite('/404');
const allArticles = await getPublishedArticles();
const posts = allArticles.filter(({ data }) => data.author === author_slug);
const categories = await getCategories();

// console.log('[author].astro, posts/author:', posts.length, author_slug);
---

<Layout title={author?.data?.name || author_slug}>
  <Container>

     <h1 class="text-center text-3xl font-bold text-gray-900 mt-10 mb-8">{author?.data?.name || author_slug}</h1>

     <AuthorCard slug={author_slug} size="md" author={author} />

      {posts.length === 0 && (
        <p class="text-center text-gray-500 mt-12">No published articles yet.</p>
      )}

      <div class="mt-16">
        <div class="flex flex-wrap justify-center gap-20">
          {Array.isArray(posts) && posts.map((post) => {
            const category = categories.find(c => c.id === post.data.category);
            const notEnglish = post.data.language && post.data.language !== 'en';
            return (
              <div className={`flex-none articlePost w-full max-w-[300px] ${notEnglish ? 'hidden' : ''}`}
                data-title={post.data.title}
                data-language={post.data.language}>
                <PostThumb post={post} author={author} category={category} />
              </div>
            );
          })}
        </div>
      </div>



      <a href="/authors" class="mt-16 text-center block w-fit mx-auto bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-4 rounded focus-visible:ring-2 focus-visible:ring-gray-500 focus-visible:outline-none">Back to Authors</a>

  </Container>
</Layout>



<script type="module" src="/js/hidePosts.js" client:idle></script>


