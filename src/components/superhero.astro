---
const quotes = [
  {
    text: "Regard man as a mine rich in gems of inestimable value. Education can, alone, cause it to reveal its treasures.",
    source: "Bahá'u'lláh",
  },
  {
    text: "The earth is but one country, and mankind its citizens.",
    source: "Bahá'u'lláh",
  },
  {
    text: "Knowledge is as wings to man's life, and a ladder for his ascent.",
    source: "Bahá'u'lláh",
  },
  {
    text: "The fundamental basis of the community is agriculture, tillage of the soil. All must be producers.",
    source: "'Abdu'l-Bahá",
  },
  {
    text: "Music is one of the arts that is of benefit — a cause of the exaltation of the human spirit.",
    source: "'Abdu'l-Bahá",
  },
  {
    text: "In the world of existence there is nothing so important as service to humanity.",
    source: "'Abdu'l-Bahá",
  },
];
---

<noscript>
  <style>
    /* Server-rendered first quote starts hidden for the JS fade-in; reveal it when JS is off. */
    #hero-quote, #hero-source { opacity: 1 !important; }
  </style>
</noscript>

<div id="superhero" class="relative w-full overflow-hidden flex flex-col">

  <!-- Video background -->
  <video loop muted autoplay playsinline preload="auto" aria-hidden="true" tabindex="-1"
    class="w-full h-full absolute inset-0 z-0 object-cover">
    <source src="/drbi-open_md.mp4" type="video/mp4">
  </video>

  <!-- Gradient overlay — heavier at bottom for quote legibility -->
  <div class="absolute inset-0 z-10 bg-gradient-to-b from-black/45 via-black/20 to-black/80"></div>

  <!-- Main headline — upper portion -->
  <div class="relative z-20 flex-1 flex flex-col items-center justify-center text-center px-6 pt-16 pb-8">
    <p class="text-white/70 text-xs uppercase tracking-[0.3em] mb-7">
      Desert Rose Bahá'í Institute &mdash; Eloy, Arizona
    </p>
    <h1 class="text-white text-4xl md:text-6xl lg:text-7xl font-serif font-light leading-tight tracking-wide max-w-4xl">
      Study deeply.<br>Grow food.<br>Build a better world.
    </h1>
    <p class="text-white/80 mt-8 text-base md:text-lg font-light tracking-wide max-w-xl leading-relaxed">
      An institute for arts, agriculture, and Bahá'í education —<br class="hidden md:block">
      open to anyone who believes the world can be transformed.
    </p>
    <a href="#programs"
      class="mt-10 inline-block border border-white/35 text-white/90 px-10 py-3.5 rounded-full text-xs tracking-[0.2em] uppercase hover:bg-white/15 focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none transition duration-300">
      Explore Programs
    </a>
  </div>

  <!-- Rotating quote — lower portion -->
  <div class="relative z-20 w-full text-center px-6 pb-14">
    <div class="w-12 h-px bg-amber-400/50 mx-auto mb-8"></div>
    <div class="max-w-2xl mx-auto min-h-[90px] flex flex-col items-center justify-center">
      <p id="hero-quote"
        class="text-white/75 text-base md:text-xl font-serif font-light italic leading-relaxed transition-opacity duration-700 opacity-0">
        {'”' + quotes[0].text + '”'}
      </p>
      <span id=”hero-source”
        class=”mt-4 block text-amber-300/70 text-xs uppercase tracking-[0.25em] transition-opacity duration-700 opacity-0”>
        {'— ' + quotes[0].source}
      </span>
    </div>
  </div>

</div>

<style>
  #superhero {
    height: 94vh;
    height: 94dvh;
    min-height: 600px;
  }
  @media (max-height: 640px) {
    #superhero { min-height: 480px; }
  }
  #superhero :is(h1, h2, h3, p, a, span, blockquote, li) {
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45), 0 0 14px rgba(0, 0, 0, 0.30);
  }
</style>

<script is:inline define:vars={{ quotes }}>
  const quoteEl  = document.getElementById('hero-quote');
  const sourceEl = document.getElementById('hero-source');
  let current = Math.floor(Math.random() * quotes.length);

  function fadeIn() {
    quoteEl.style.opacity  = '1';
    sourceEl.style.opacity = '1';
  }
  function fadeOut(cb) {
    quoteEl.style.opacity  = '0';
    sourceEl.style.opacity = '0';
    setTimeout(cb, 700);
  }

  function showQuote(index) {
    const q = quotes[index];
    fadeOut(() => {
      quoteEl.textContent  = '“' + q.text + '”';
      sourceEl.textContent = '— ' + q.source;
      fadeIn();
      setTimeout(() => {
        current = (current + 1) % quotes.length;
        showQuote(current);
      }, 8000);
    });
  }

  // First quote fades in after the page settles
  setTimeout(() => {
    const q = quotes[current];
    quoteEl.textContent  = '“' + q.text + '”';
    sourceEl.textContent = '— ' + q.source;
    fadeIn();
    setTimeout(() => {
      current = (current + 1) % quotes.length;
      showQuote(current);
    }, 8000);
  }, 1200);
</script>
