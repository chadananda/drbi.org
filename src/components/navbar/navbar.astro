---
import Container from "@components/container.astro";
import { StickyHeader } from "astro-navbar";
import SiteLogo from "@components/siteLogo.astro";
import links from "@data/siteLinks.json";
const menuLinks = links.menuLinks;

// Auth state (set on every request by middleware.ts). Sign-in happens right here in
// the navbar popover — there is no login page.
const user = Astro.locals?.user ?? null;
const isStaff = !!user && ['superadmin', 'admin', 'editor', 'author'].includes(user.role);
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
---

<StickyHeader
  class="sticky top-0 border-b transition-all z-50"
  scrollY={50}
  defaultClass="py-2 border-transparent"
  activeClass="py-2 bg-white/80 border-gray-200 backdrop-blur-lg">
  <Container>
    <div class="flex items-center justify-between gap-2 relative z-10" transition:animate="none">
      <!-- Logo -->
      <div id="logo" class="flex items-center shrink-0">
        <SiteLogo />
      </div>

      <!-- Priority+ links: shows as many as fit; the rest are moved into the hamburger by JS -->
      <nav id="primary-nav" aria-label="Primary" class="flex flex-1 min-w-0 items-center justify-center gap-1 overflow-hidden noprint">
        {menuLinks.map((item) => (
          <a href={item.path} data-astro-reload
            class="nav-link whitespace-nowrap px-3 py-2 text-sm text-gray-600 hover:text-amber-700 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-amber-500 focus-visible:outline-none transition rounded-full">
            {item.title}
          </a>
        ))}
      </nav>

      <!-- Right controls: Contribute · hamburger (only when links overflow) · profile -->
      <div class="flex items-center gap-2 shrink-0 noprint">
        <a href="/contribute" data-astro-reload
          class="hidden sm:inline-flex px-5 py-2 text-sm font-medium text-white bg-amber-700 hover:bg-amber-600 rounded-full transition duration-200">
          Contribute
        </a>

        <!-- Hamburger — hidden until JS detects overflow -->
        <button id="nav-more" type="button" aria-label="More menu" aria-expanded="false" aria-controls="nav-overflow"
          class="hidden items-center justify-center w-10 h-10 rounded-full text-gray-700 hover:bg-gray-100 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-amber-500 focus-visible:outline-none transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <!-- Profile / account — opens the login/account popover in place (no login page) -->
        <div class="relative shrink-0">
          <button id="account-btn" type="button" aria-label="Account" title="Account" aria-expanded="false" aria-controls="account-menu"
            class:list={["inline-flex items-center justify-center w-10 h-10 rounded-full text-gray-700 hover:bg-gray-100 hover:text-amber-700 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-amber-500 focus-visible:outline-none transition", user ? "ring-2 ring-amber-500" : "ring-1 ring-gray-200"]}>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </button>

          <div id="account-menu" class="hidden absolute right-0 top-full mt-2 w-72 bg-white border border-gray-200 rounded-xl shadow-lg p-4 z-50 text-left">
            {user ? (
              <div>
                <p class="text-xs text-gray-400">Signed in as</p>
                <p class="text-sm font-semibold text-gray-900 truncate">{user.name || user.email}</p>
                <p class="text-xs text-gray-400 mb-3 capitalize">{user.role}</p>
                {isStaff && (
                  <a href="/admin" class="block w-full text-center mb-2 px-4 py-2 text-sm font-medium text-white bg-amber-700 hover:bg-amber-600 rounded-full transition">Admin panel</a>
                )}
                <button id="signout-btn" type="button" class="block w-full px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-full transition">Sign out</button>
              </div>
            ) : (
              <div>
                <div class="flex items-center justify-between mb-3">
                  <p class="text-sm font-semibold text-gray-900">Sign in</p>
                  <button id="nav-signin-close" type="button" aria-label="Close" class="text-gray-400 hover:text-gray-700 focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:outline-none rounded">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  </button>
                </div>
                {googleClientId && (
                  <div class="mb-3">
                    {/* The One Tap config (#g_id_onload) lives at the top level, NOT here —
                        GIS mis-places the prompt when its config is inside a display:none popover. */}
                    <div class="g_id_signin" data-type="standard" data-width="256"></div>
                  </div>
                )}
                <form id="nav-magic-form" class="space-y-2">
                  <input type="email" id="nav-magic-email" name="email" required placeholder="you@example.com"
                    class="w-full border border-gray-300 rounded-lg py-2 px-3 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-amber-500" />
                  <button type="submit" class="w-full px-4 py-2 text-sm font-medium text-white bg-amber-700 hover:bg-amber-600 rounded-full transition">Email me a sign-in link</button>
                </form>
                <details class="mt-3">
                  <summary class="text-xs text-gray-400 cursor-pointer">Superadmin password</summary>
                  <form id="nav-pass-form" class="mt-2 space-y-2">
                    <input type="email" name="email" placeholder="Email" required class="w-full border border-gray-300 rounded-lg py-2 px-3 text-sm" />
                    <input type="password" name="password" placeholder="Password" required class="w-full border border-gray-300 rounded-lg py-2 px-3 text-sm" />
                    <button type="submit" class="w-full px-4 py-2 text-sm text-white bg-gray-700 hover:bg-gray-900 rounded-full transition">Sign in</button>
                  </form>
                </details>
                <p id="nav-auth-msg" class="text-sm mt-2" role="alert"></p>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Overflow dropdown (holds the links that didn't fit) -->
      <div id="nav-overflow" class="hidden absolute right-0 top-full mt-2 w-60 bg-white border border-gray-200 rounded-xl shadow-lg py-2 z-50">
        <div id="nav-overflow-list" class="flex flex-col"></div>
        <div id="nav-overflow-cta" class="sm:hidden mt-2 px-3 pt-2 border-t border-gray-100">
          <a href="/contribute" data-astro-reload
            class="flex justify-center px-5 py-2 text-sm font-medium text-white bg-amber-700 hover:bg-amber-600 rounded-full transition">
            Contribute
          </a>
        </div>
      </div>
    </div>
  </Container>
</StickyHeader>

<style>
  /* In the dropdown, links stack full-width and lose the pill hover for a cleaner list */
  #nav-overflow-list .nav-link { display: block; border-radius: 0.5rem; }
</style>

<script>
  function setupResponsiveNav() {
    const nav = document.getElementById('primary-nav');
    const list = document.getElementById('nav-overflow-list');
    const panel = document.getElementById('nav-overflow');
    const moreBtn = document.getElementById('nav-more');
    if (!nav || !list || !panel || !moreBtn) return;
    if (nav.dataset.priorityNav === 'on') return; // already initialised for this DOM
    nav.dataset.priorityNav = 'on';

    const closePanel = () => { panel.classList.add('hidden'); moreBtn.setAttribute('aria-expanded', 'false'); };
    const openPanel = () => { if (!list.children.length) return; panel.classList.remove('hidden'); moreBtn.setAttribute('aria-expanded', 'true'); };

    function reflow() {
      // Move everything back into the row, then push overflow (from the end) into the dropdown.
      while (list.firstElementChild) nav.appendChild(list.firstElementChild);
      let guard = 100;
      while (nav.scrollWidth > nav.clientWidth + 1 && nav.lastElementChild && guard-- > 0) {
        list.insertBefore(nav.lastElementChild, list.firstElementChild);
      }
      const hasOverflow = list.children.length > 0;
      // Toggle both: Tailwind's `inline-flex` would otherwise win over `hidden` in source order.
      moreBtn.classList.toggle('hidden', !hasOverflow);
      moreBtn.classList.toggle('inline-flex', hasOverflow);
      if (!hasOverflow) closePanel();
    }

    moreBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      panel.classList.contains('hidden') ? openPanel() : closePanel();
    });
    document.addEventListener('click', (e) => {
      if (!panel.contains(e.target) && e.target !== moreBtn && !moreBtn.contains(e.target)) closePanel();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePanel(); });
    list.addEventListener('click', () => closePanel());

    reflow();
    if (window.ResizeObserver) new ResizeObserver(() => reflow()).observe(document.body);
    window.addEventListener('resize', reflow);
    window.addEventListener('load', reflow); // fonts/logo may shift widths after load
  }

  if (document.readyState !== 'loading') setupResponsiveNav();
  else document.addEventListener('DOMContentLoaded', setupResponsiveNav);
  document.addEventListener('astro:page-load', setupResponsiveNav);
</script>

{!user && googleClientId && (
  <Fragment>
    {/* auto_prompt is OFF: Google's One Tap prompt is FedCM-controlled and floats over the
        navbar with no way to reposition it (mandatory FedCM since Aug 2025). Instead we
        auto-open our own popover (below the profile button) — see the script below. This
        g_id_onload only configures GIS so the rendered "Sign in with Google" button works. */}
    <div id="g_id_onload" data-client_id={googleClientId} data-callback="handleNavGoogle" data-auto_prompt="false"></div>
    <script is:inline src="https://accounts.google.com/gsi/client" async></script>
  </Fragment>
)}

<script is:inline>
  (function () {
    const btn = document.getElementById('account-btn');
    const menu = document.getElementById('account-menu');
    const msgEl = () => document.getElementById('nav-auth-msg');
    const setMsg = (text, ok) => { const m = msgEl(); if (m) { m.textContent = text; m.className = 'text-sm mt-2 ' + (ok ? 'text-green-600' : 'text-red-500'); } };

    if (btn && menu) {
      const loggedOut = !!document.getElementById('nav-magic-form');
      const PROMPTED = 'drbi_login_prompted';
      const wasPrompted = () => { try { return sessionStorage.getItem(PROMPTED) === '1'; } catch (e) { return false; } };
      const markPrompted = () => { try { sessionStorage.setItem(PROMPTED, '1'); } catch (e) {} };
      const isOpen = () => !menu.classList.contains('hidden');
      const open = () => { menu.classList.remove('hidden'); btn.setAttribute('aria-expanded', 'true'); };
      const close = () => { menu.classList.add('hidden'); btn.setAttribute('aria-expanded', 'false'); };
      // Closing the sign-in popover counts as "seen it" — don't auto-reopen this session.
      const dismiss = () => { close(); markPrompted(); };
      btn.addEventListener('click', (e) => { e.stopPropagation(); isOpen() ? dismiss() : open(); });
      document.addEventListener('click', (e) => { if (isOpen() && !menu.contains(e.target) && !btn.contains(e.target)) dismiss(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen()) dismiss(); });
      document.getElementById('nav-signin-close')?.addEventListener('click', (e) => { e.stopPropagation(); dismiss(); });

      // Arriving from a bounce (?signin=1) or a failed magic link (?auth_error=…): open the popover.
      const params = new URLSearchParams(location.search);
      const forced = params.get('signin') === '1' || !!params.get('auth_error');
      if (params.get('signin') === '1') open();
      const err = params.get('auth_error');
      if (err) { setMsg(err === 'invalid-or-expired' ? 'That sign-in link was invalid or expired. Request a new one.' : 'That account has been disabled. Contact an administrator.', false); open(); }

      // Auto-open our sign-in popover below the navbar (replaces Google's over-the-navbar One Tap).
      // Once per session for logged-out visitors, after the page settles; dismissing stops it.
      if (loggedOut && !forced && !wasPrompted()) {
        setTimeout(() => { if (!isOpen()) { open(); markPrompted(); } }, 900);
      }
    }

    // Google One Tap / button callback (auto-prompts when signed into Google).
    window.handleNavGoogle = async (response) => {
      try {
        const r = await fetch('/api/auth/google', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ credential: response.credential }) });
        const data = await r.json();
        if (data.ok) { location.reload(); }
        else { setMsg(data.error === 'account-disabled' ? 'That account has been disabled. Contact an administrator.' : 'Google sign-in failed.', false); }
      } catch { setMsg('Google sign-in failed.', false); }
    };

    document.getElementById('nav-magic-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('nav-magic-email').value.trim();
      await fetch('/api/auth/request-link', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email }) }).catch(() => {});
      setMsg('If that email is authorized, a sign-in link is on its way. Check your inbox.', true);
    });

    document.getElementById('nav-pass-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const r = await fetch('/api/auth/password', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: fd.get('email'), password: fd.get('password') }) }).catch(() => null);
      const data = r && await r.json().catch(() => null);
      if (data && data.ok) { location.href = data.redirect || '/admin'; }
      else { setMsg('Invalid email or password.', false); }
    });

    document.getElementById('signout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' }).catch(() => {});
      location.reload();
    });
  })();
</script>
