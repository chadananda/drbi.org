---
import Container from "@components/container.astro";
import { StickyHeader } from "astro-navbar";
import SiteLogo from "@components/siteLogo.astro";
import links from "@data/siteLinks.json";
const menuLinks = links.menuLinks;
---

<StickyHeader
  class="sticky top-0 border-b transition-all z-50"
  scrollY={50}
  defaultClass="py-2 border-transparent"
  activeClass="py-2 bg-white/80 border-gray-200 backdrop-blur-lg">
  <Container>
    <div class="flex items-center justify-between gap-2 relative z-10" transition:animate="none">
      <!-- Logo -->
      <div id="logo" class="flex items-center shrink-0">
        <SiteLogo />
      </div>

      <!-- Priority+ links: shows as many as fit; the rest are moved into the hamburger by JS -->
      <nav id="primary-nav" aria-label="Primary" class="flex flex-1 min-w-0 items-center gap-1 overflow-hidden noprint">
        {menuLinks.map((item) => (
          <a href={item.path} data-astro-reload
            class="nav-link whitespace-nowrap px-3 py-2 text-sm text-gray-600 hover:text-amber-700 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-amber-500 focus-visible:outline-none transition rounded-full">
            {item.title}
          </a>
        ))}
      </nav>

      <!-- Right controls: Contribute · hamburger (only when links overflow) · profile -->
      <div class="flex items-center gap-2 shrink-0 noprint">
        <a href="/contribute" data-astro-reload
          class="hidden sm:inline-flex px-5 py-2 text-sm font-medium text-white bg-amber-700 hover:bg-amber-600 rounded-full transition duration-200">
          Contribute
        </a>

        <!-- Hamburger — hidden until JS detects overflow -->
        <button id="nav-more" type="button" aria-label="More menu" aria-expanded="false" aria-controls="nav-overflow"
          class="hidden items-center justify-center w-10 h-10 rounded-full text-gray-700 hover:bg-gray-100 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-amber-500 focus-visible:outline-none transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <!-- Profile / account -->
        <a href="/admin" data-astro-reload aria-label="Account" title="Account"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full text-gray-700 ring-1 ring-gray-200 hover:bg-gray-100 hover:text-amber-700 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-amber-500 focus-visible:outline-none transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </a>
      </div>

      <!-- Overflow dropdown (holds the links that didn't fit) -->
      <div id="nav-overflow" class="hidden absolute right-0 top-full mt-2 w-60 bg-white border border-gray-200 rounded-xl shadow-lg py-2 z-50">
        <div id="nav-overflow-list" class="flex flex-col"></div>
        <div id="nav-overflow-cta" class="sm:hidden mt-2 px-3 pt-2 border-t border-gray-100">
          <a href="/contribute" data-astro-reload
            class="flex justify-center px-5 py-2 text-sm font-medium text-white bg-amber-700 hover:bg-amber-600 rounded-full transition">
            Contribute
          </a>
        </div>
      </div>
    </div>
  </Container>
</StickyHeader>

<style>
  /* In the dropdown, links stack full-width and lose the pill hover for a cleaner list */
  #nav-overflow-list .nav-link { display: block; border-radius: 0.5rem; }
</style>

<script>
  function setupResponsiveNav() {
    const nav = document.getElementById('primary-nav');
    const list = document.getElementById('nav-overflow-list');
    const panel = document.getElementById('nav-overflow');
    const moreBtn = document.getElementById('nav-more');
    if (!nav || !list || !panel || !moreBtn) return;
    if (nav.dataset.priorityNav === 'on') return; // already initialised for this DOM
    nav.dataset.priorityNav = 'on';

    const closePanel = () => { panel.classList.add('hidden'); moreBtn.setAttribute('aria-expanded', 'false'); };
    const openPanel = () => { if (!list.children.length) return; panel.classList.remove('hidden'); moreBtn.setAttribute('aria-expanded', 'true'); };

    function reflow() {
      // Move everything back into the row, then push overflow (from the end) into the dropdown.
      while (list.firstElementChild) nav.appendChild(list.firstElementChild);
      let guard = 100;
      while (nav.scrollWidth > nav.clientWidth + 1 && nav.lastElementChild && guard-- > 0) {
        list.insertBefore(nav.lastElementChild, list.firstElementChild);
      }
      const hasOverflow = list.children.length > 0;
      // Toggle both: Tailwind's `inline-flex` would otherwise win over `hidden` in source order.
      moreBtn.classList.toggle('hidden', !hasOverflow);
      moreBtn.classList.toggle('inline-flex', hasOverflow);
      if (!hasOverflow) closePanel();
    }

    moreBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      panel.classList.contains('hidden') ? openPanel() : closePanel();
    });
    document.addEventListener('click', (e) => {
      if (!panel.contains(e.target) && e.target !== moreBtn && !moreBtn.contains(e.target)) closePanel();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePanel(); });
    list.addEventListener('click', () => closePanel());

    reflow();
    if (window.ResizeObserver) new ResizeObserver(() => reflow()).observe(document.body);
    window.addEventListener('resize', reflow);
    window.addEventListener('load', reflow); // fonts/logo may shift widths after load
  }

  if (document.readyState !== 'loading') setupResponsiveNav();
  else document.addEventListener('DOMContentLoaded', setupResponsiveNav);
  document.addEventListener('astro:page-load', setupResponsiveNav);
</script>
