---
// Admin shell. Uses the SAME site navbar as the public pages (its profile menu holds the
// role-based admin links). Full-width content — no separate admin chrome.
export const prerender = false;

import "../styles/tailwind.css";
import Navbar from "@components/navbar/navbar.astro";

interface Props {
  title?: string;
  description?: string;
  user?: any;
}
const { title = "Admin Dashboard", description = "DRBI Content Management System" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} — DRBI Admin</title>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">
  <Navbar />
  <main class="w-full px-4 sm:px-6 lg:px-8 py-6">
    <slot />
  </main>
</body>
</html>
