---
export const prerender = true;
import Layout from "./Layout.astro";
import PageHero from "@components/PageHero.astro";
import Container from "@components/container.astro";

import artsImg from "../assets/drbi/arts.webp";
import cemeteryImg from "../assets/drbi/cemetery.webp";
import studyImg from "../assets/drbi/study.webp";
import soilImg from "../assets/drbi/soil.webp";
import kureImg from "../assets/drbi/kure.webp";
import memoriesImg from "../assets/drbi/memories.webp";
import contributeImg from "../assets/drbi/contribute.webp";
import eventsImg from "../assets/drbi/events.webp";
import faithImg from "../assets/drbi/faith.webp";
import newsImg from "../assets/drbi/news.webp";
import casasImg from "../pages/history/_casas.webp";
import hallImg from "../pages/history/_hall.webp";
import pavilionImg from "../pages/history/_pavilion.webp";
import roundhouseImg from "../pages/history/_Round-House.webp";
import guesthouseImg from "../pages/history/_guest_house.webp";
import farmImg from "../pages/history/_farm.webp";

const { frontmatter } = Astro.props;

const imageMap = {
  arts: artsImg,
  cemetery: cemeteryImg,
  study: studyImg,
  soil: soilImg,
  kure: kureImg,
  casas: casasImg,
  hall: hallImg,
  pavilion: pavilionImg,
  roundhouse: roundhouseImg,
  guesthouse: guesthouseImg,
  farm: farmImg,
  memories: memoriesImg,
  contribute: contributeImg,
  events: eventsImg,
  faith: faithImg,
  news: newsImg,
};
const heroImage = (imageMap as Record<string, any>)[frontmatter.image] ?? undefined;
const heroPosition = frontmatter.imagePosition ?? "object-center";
---

<Layout title={frontmatter.title} description={frontmatter.description} image={frontmatter.image}>

  <PageHero
    label={frontmatter.label}
    title={frontmatter.title}
    subtitle={frontmatter.subtitle}
    image={heroImage}
    imageAlt={frontmatter.title}
    imagePosition={heroPosition}
  />

  <div class="py-16 bg-white">
    <Container>
      <div class="mx-auto prose prose-lg prose-slate
        prose-headings:font-serif prose-headings:font-light prose-headings:text-slate-800
        prose-h2:text-3xl prose-h2:mt-14 prose-h2:mb-5
        prose-h3:text-xl prose-h3:mt-10 prose-h3:mb-3
        prose-p:text-slate-600 prose-p:leading-relaxed
        prose-a:text-amber-700 prose-a:no-underline hover:prose-a:underline
        prose-blockquote:border-amber-400 prose-blockquote:text-slate-500 prose-blockquote:italic
        prose-strong:text-slate-700
        max-w-[80ch]">
        <slot />
      </div>
    </Container>
  </div>

</Layout>

<style is:global>
  @media screen { .printonly { display: none !important; } }
  @media print  { .printonly { display: block !important; } .noprint { display: none !important; } }
</style>
