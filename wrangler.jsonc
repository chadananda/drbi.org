{
  // Cloudflare Workers config for drbi.org (replaced the blogworks-hosted site at cutover).
  // Serves the live drbi.org + www via custom domains. Scope: drbi-* resources only.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "drbi-preview",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "routes": [
    { "pattern": "drbi.org", "custom_domain": true },
    { "pattern": "www.drbi.org", "custom_domain": true }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "drbi-db",
      "database_id": "cc53feb7-5a9f-4754-9256-4a4c53edd4a2"
    }
  ],
  "r2_buckets": [
    {
      // access granted only under the drbi.org/ prefix; wired in Phase 2 uploads work
      "binding": "R2",
      "bucket_name": "cdn-assets"
    }
  ],
  "kv_namespaces": [
    {
      // adapter auto-enables Astro sessions on this binding; reuse existing SESSION namespace
      "binding": "SESSION",
      "id": "7f25aeca4da74de38f5cde68b5bac874"
    }
  ]
}
